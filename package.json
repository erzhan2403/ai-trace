{
  "name": "ai-trace",
  "version": "0.1.0",
  "description": "Local, open-source, vendor-neutral tracing SDK and CLI for AI agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ai-trace": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "example": "tsx examples/basic-agent.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
